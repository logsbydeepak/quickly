---
import { generate } from "random-words";
import BaseLayout from "../components/BaseLayout.astro";
import Footer from "../components/Footer.astro";
import Logo from "../components/Logo.astro";
import SearchChips from "../components/SearchChips.astro";
import SearchForm from "../components/SearchForm.astro";
import ThemeToggle from "../components/ThemeToggle.astro";

const generatedChips = generate({ exactly: 6 });
const chips = Array.isArray(generatedChips) ? generatedChips : ["Trending", "News", "Sports", "Finance", "Technology", "Science"];
const apiUrl = import.meta.env.PUBLIC_API_URL ?? "http://localhost:5000";
---

<BaseLayout title="Quickly - Search the web, fast." apiUrl={apiUrl}>
  <div class="flex min-h-screen flex-col bg-[#f5f2ee] dark:bg-[#0f0e0c]">
    <nav class="flex items-center justify-between px-7 py-4">
      <div></div>
      <div class="flex items-center gap-3">
        <ThemeToggle />
      </div>
    </nav>

    <main class="flex flex-1 flex-col items-center justify-center px-6 pb-[18vh]">
      <div class="mb-10 flex animate-fade-up flex-col items-center gap-1">
        <Logo size="lg" />
        <p class="mt-2 text-sm font-light tracking-[0.12em] text-[#8a837a] dark:text-[#6e6760]">Search the web, fast.</p>
      </div>

      <SearchForm autofocus showActions />
      <SearchChips chips={chips} />

      <p class="mt-10 animate-fade-up delay-3 text-[11px] text-[#8a837a]/60 dark:text-[#6e6760]/60">
        Press <kbd class="rounded bg-black/[0.06] px-1.5 py-0.5 font-mono text-[10px] dark:bg-white/[0.06]">Enter</kbd> or click the search button to search
      </p>
    </main>

    <Footer />
  </div>
</BaseLayout>
