---
import Logo from "./Logo.astro";
import SearchForm from "./SearchForm.astro";
import ThemeToggle from "./ThemeToggle.astro";

interface Props {
  query: string;
}

const { query } = Astro.props;
---

<header class="sticky top-0 z-50 flex items-center gap-4 border-b border-black/[0.07] bg-[#f5f2ee]/90 px-6 py-3 backdrop-blur-md dark:border-white/[0.06] dark:bg-[#0f0e0c]/90">
  <a href="/" class="shrink-0"><Logo size="sm" /></a>
  <SearchForm query={query} compact />
  <div class="ml-auto shrink-0">
    <ThemeToggle />
  </div>
</header>
