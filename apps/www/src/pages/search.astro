---
import BaseLayout from "../components/BaseLayout.astro";
import Footer from "../components/Footer.astro";
import Pagination from "../components/Pagination.astro";
import QuickFacts from "../components/QuickFacts.astro";
import RelatedSearches from "../components/RelatedSearches.astro";
import ResultsHeader from "../components/ResultsHeader.astro";
import ResultsList from "../components/ResultsList.astro";

export const prerender = false;

interface SearchResult {
  url?: string;
  title?: string;
  description?: string;
}

const apiUrl = import.meta.env.PUBLIC_API_URL ?? "http://127.0.0.1:5000";
const query = Astro.url.searchParams.get("q") || "Trending";
const page = Math.max(Number.parseInt(Astro.url.searchParams.get("page") || "1", 10) || 1, 1);

const emptyPayload = {
  results: [] as SearchResult[],
  meta: {
    search_speed_ms: 0,
    total_results: 0,
  },
  pagination: {
    page,
    page_size: 10,
    total_pages: 0,
    has_next: false,
    has_previous: false,
  },
};

let payload = emptyPayload;
let searchError = false;

try {
  const searchUrl = new URL("/search", apiUrl);
  searchUrl.searchParams.set("q", query);
  searchUrl.searchParams.set("page", String(page));
  const response = await fetch(searchUrl);
  if (!response.ok) throw new Error(`Search failed with ${response.status}`);
  payload = await response.json();
} catch (error) {
  searchError = true;
  console.error(error);
}

const results = payload.results || [];
const pagination = payload.pagination || emptyPayload.pagination;
const totalResults = payload.meta?.total_results ?? results.length;
const speedSeconds = ((payload.meta?.search_speed_ms ?? 0) / 1000).toFixed(2);
const currentPage = pagination.page || page;
const totalPages = pagination.total_pages || 1;
const relatedSearches = [
  `${query} explained`,
  `${query} examples`,
  `${query} tutorial`,
  `best ${query}`,
  `${query} history`,
  `how to use ${query}`,
];
---

<BaseLayout title={`${query} - Quickly`} description={`Search results for ${query} on Quickly.`} apiUrl={apiUrl}>
  <div data-results-page data-server-rendered class="flex min-h-screen flex-col bg-[#f5f2ee] dark:bg-[#0f0e0c]">
    <ResultsHeader query={query} />

    <main class="mx-auto flex w-full max-w-[1100px] flex-1 gap-10 px-6 pb-12 pt-5">
      <section class="min-w-0 flex-1">
        <p class="mb-5 text-[13px] font-light text-[#8a837a] dark:text-[#6e6760]">
          {searchError ? "Search failed." : <>Page {currentPage} of {totalPages}</>}
        </p>

        <ResultsList results={results} searchError={searchError} />
        <Pagination query={query} pagination={pagination} currentPage={currentPage} totalPages={totalPages} />
        <RelatedSearches items={relatedSearches} />
      </section>

      <QuickFacts speedSeconds={speedSeconds} totalResults={totalResults} />
    </main>

    <Footer showLocation />
  </div>
</BaseLayout>
